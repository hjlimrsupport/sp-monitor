# --- GitHub Configuration ---
GITHUB_TOKEN=your_personal_access_token_here
GITHUB_USER=hjlimrsupport
GITHUB_REPO=sp-monitor

# --- Gemini API Keys (Comma separated for Robust Client) ---
# 여러 개일 경우 쉼표(,)로 구분하여 입력하세요.
GEMINI_API_KEYS=key1,key2,key3

# --- Google Workspace (Sheets/Drive) ---
# 구글 시트 ID (URL에서 d/ 와 /edit 사이의 문자열)
GOOGLE_SHEET_ID=your_spreadsheet_id_here
# 서비스 계정 JSON 파일 경로
GOOGLE_APPLICATION_CREDENTIALS=./config/google_service_account.json

# --- 기타 설정 ---
MONITOR_INTERVAL_HOURS=24
